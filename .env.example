# =========================================================================
# SIEM DATA SCIENTIST - CONFIGURAÇÃO DE SEGURANÇA E PRODUÇÃO
# =========================================================================
# Copie este arquivo para um arquivo chamado '.env' na raiz do projeto
# e preencha os valores reais correspondentes para ambiente de produção.
#
# AVISO: Nunca commite o arquivo '.env' real com credenciais ativas!
# =========================================================================

# Configurações do Servidor
PORT=8501
HOST=0.0.0.0

# Nível do Ambiente (development / production)
ENVIRONMENT=production

# Chaves de API e Tokens de Integração (Exemplo)
# ATENÇÃO: Nunca adicione prefixos do tipo 'NEXT_PUBLIC_' para chaves que 
# devem permanecer secretas no backend/servidor.
API_SECURITY_FEED_KEY=seu_token_secreto_aqui
DATABASE_URL=postgresql://user:password@localhost:5432/siem_db
SECRET_KEY=sua_chave_secreta_para_assinatura_de_cookies
